<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <style>
        table {
            width: 70%;
            margin: 50px auto;
            border-collapse: collapse;
            font-family: Arial, sans-serif;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
            border-radius: 10px;
            overflow: hidden;
        }

        /* Header styling */
        th {
            background-color: #4CAF50;
            color: white;
            text-align: left;
            padding: 14px;
            font-size: 16px;
        }

        /* Cell styling */
        td {
            padding: 12px 14px;
            border-bottom: 1px solid #ddd;
        }

        /* Zebra striping */
        tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        /* Hover effect */
        tr:hover {
            background-color: #f1f1f1;
            transition: 0.3s;
        }

        /* Make header text uppercase */
        th {
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .available{
            text-transform: capitalize;
        }
        .addbtn{
            text-decoration: none;
            color:#ffff;
            background-color: #d89b0d;
            padding:10px 5px;
            border-radius: 5px;
        }
        .addbtn:hover{
            background-color: #054a07;
        }
        .editbtn{
            display: inline-block;
            text-decoration: none;
            text-transform: uppercase;
            color:#0d43d8;
            cursor: pointer;
            border: none;
            background-color:transparent;
        }
        .editbtn:hover{
            color:#13cc32;
        }
        .deletebtn{
            display: inline-block;
            text-transform: uppercase;
            text-decoration: none;
            margin-left:20px;
            color:#f45047;
            cursor: pointer;
            border: none;
            background-color: transparent;
        }
        .deletebtn:hover{
            color:#810a04
        }
        .subbtn{
            display: inline-block;
            padding:7px 12px;
            color:#ffff;
            border-color: none;
            border: none;
            background-color:#4CAF50;
            border-radius: 5px;
        }
        .subbtn:hover{
            background-color: #054a07;
        }
        .darkletter{
            color:black;
        }
        .delbn{
            background-color:#f45047;
            color:#ffff;
        }
        .delbn:hover{
            background-color:#810a04
        }
    </style>
</head>
<body>
    {{{body}}}
</body>
</html>