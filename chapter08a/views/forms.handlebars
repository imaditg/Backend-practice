<form action="/form-submit" method="GET" class="form-outer">
<div class="items">
    <h3>SIGN UP</h3>
</div>
    <div class="items">
        <label for="fieldName">Name: </label>
        <input type="text" name="name" class="na">
    </div>
    <div class="items">
        <label for="email">Email: </label>
        <input type="email" name="email" class="na">
    </div>
    <div class="items">
        <button type="submit" class="sub">Submit</button>
    </div>
</form>