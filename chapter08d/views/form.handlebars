<form class="form-outer" method="POST" action="/signup-upload" enctype="multipart/form-data" id="signupform">
    <input type="hidden" name="_csrf" value="{{csrf}}">
    <div class="items">
        <h3>SIGN UP</h3>
    </div>
    <div class="items">
        <label for="fieldName">Name: </label>
        <input type="text" name="name" class="na">
    </div>
    <div class="items">
        <label for="email">Email: </label>
        <input type="email" name="email" class="na">
    </div>
    <div class="items">
        <label for="photo">Upload: </label>
        <input type="file" name="photo">
    </div>
    <div class="items">
        <button type="submit" class="sub">Submit</button>
    </div>
</form>